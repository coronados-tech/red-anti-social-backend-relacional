PORT=3001
MESES=6
IDIOMA=es

# URL pública del backend (para URLs de imágenes en seed y uploads nuevos)
# PUBLIC_BASE_URL=https://red-anti-social-backend-relacional.vercel.app

# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://red-anti-social.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://red-anti-social.vercel.app

# Swagger UI en /swagger (true para habilitar en producción; por defecto solo fuera de NODE_ENV=production)
# ENABLE_SWAGGER=true

# Caché en memoria para GET de posts (false para desactivar)
CACHE_POSTS_ENABLED=true

# Segundos de validez del caché (se invalida antes al crear/editar/borrar posts)
CACHE_POSTS_TTL_SECONDS=60

# Demora artificial en GET /posts paginado (ms). 0 para desactivar.
POSTS_PAGINATION_DELAY_MS=1500

# Base de datos (sqlite | mysql | mariadb | postgres)
# Local: DB_DIALECT=sqlite
DB_DIALECT=sqlite

# SQLite (solo local; en Vercel no definir DB_STORAGE)
DB_STORAGE=data/datastore.db

# --- PRODUCCIÓN EN VERCEL (recomendado: Neon PostgreSQL gratis) ---
# 1. Crear cuenta en https://neon.tech
# 2. New Project → copiar "Connection string" (postgresql://...)
# 3. En Vercel → Settings → Environment Variables, agregar SOLO estas:
#
# DATABASE_URL=postgresql://usuario:password@host/neondb?sslmode=require
# JWT_SECRET=un-secreto-largo-y-aleatorio
# CORS_ORIGIN=https://tu-frontend.vercel.app
#
# NO agregar DB_DIALECT=mysql ni DB_HOST si usás DATABASE_URL.
# Borrar variables viejas: DB_STORAGE, DB_HOST, DB_USER, DB_PASSWORD si no las usás.

# MySQL / PostgreSQL (alternativa manual sin DATABASE_URL)
# DB_DIALECT=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=anti-social
# DB_USER=postgres
# DB_PASSWORD=

# Logs SQL de Sequelize (true | false)
DB_LOGGING=false

# JWT (login)
JWT_SECRET=cambiar-por-un-secreto-seguro-en-produccion
JWT_EXPIRES_IN=7d

# Sincronización de Sequelize al iniciar
# Por defecto solo crea tablas faltantes. Las columnas nuevas se agregan con migraciones automáticas.
# DB_SYNC_FORCE=true   # borra y recrea todas las tablas (solo reset manual)
