PORT=3001
MESES=6
IDIOMA=es

# Orígenes permitidos para CORS (separados por coma)
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://tu-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Swagger UI en /swagger (true para habilitar en producción; por defecto solo fuera de NODE_ENV=production)
# ENABLE_SWAGGER=true

# Caché en memoria para GET de posts (false para desactivar)
CACHE_POSTS_ENABLED=true

# Segundos de validez del caché (se invalida antes al crear/editar/borrar posts)
CACHE_POSTS_TTL_SECONDS=60

# Demora artificial en GET /posts paginado (ms). 0 para desactivar.
POSTS_PAGINATION_DELAY_MS=1500

# Base de datos (sqlite | mysql | mariadb | postgres)
# En Vercel usar postgres (Neon, Supabase, etc.). SQLite en /tmp es solo para pruebas y no persiste.
DB_DIALECT=sqlite

# SQLite (solo cuando DB_DIALECT=sqlite)
# En Vercel se usa /tmp/datastore.db automáticamente si no se define DB_STORAGE
DB_STORAGE=data/datastore.db

# MySQL / MariaDB / PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=anti-social
DB_USER=root
DB_PASSWORD=

# Logs SQL de Sequelize (true | false)
DB_LOGGING=false

# JWT (login)
JWT_SECRET=cambiar-por-un-secreto-seguro-en-produccion
JWT_EXPIRES_IN=7d

# Sincronización de Sequelize al iniciar
# Por defecto solo crea tablas faltantes. Las columnas nuevas se agregan con migraciones automáticas.
# DB_SYNC_FORCE=true   # borra y recrea todas las tablas (solo reset manual)
